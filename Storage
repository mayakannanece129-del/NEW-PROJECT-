const Scheduler = {
  checkConflict(tt, day, slot, facultyName, roomId, subjectCode){
    for(const key in tt){
      const [d,s] = key.split('|');
      if(d!==day || s!==slot) continue;
      const e = tt[key];
      if(e.faculty===facultyName) return `Faculty ${facultyName} busy at ${day} ${slot}`;
      if(e.room===roomId) return `Room ${roomId} occupied at ${day} ${slot}`;
    }
    return null;
  },
  assign(day, slot, subjectCode, roomId){
    const subs = Storage.get(KEYS.subjects);
    const sub = subs.find(x=>x.code===subjectCode);
    if(!sub){ return 'Subject not found'; }
    const tt = Storage.get(KEYS.tt, {});
    const key = `${day}|${slot}`;
    if(tt[key]) return `Slot ${day} ${slot} already used`;
    const conflict = this.checkConflict(tt, day, slot, sub.faculty, roomId, subjectCode);
    if(conflict) return conflict;
    tt[key] = {code:sub.code, name:sub.name, faculty:sub.faculty, room:roomId};
    Storage.set(KEYS.tt, tt);
    return null;
  },
  remove(day, slot){
    const tt = Storage.get(KEYS.tt, {});
    delete tt[`${day}|${slot}`];
    Storage.set(KEYS.tt, tt);
  },
  autoGenerate(){
    const subs = Storage.get(KEYS.subjects);
    const rooms = Storage.get(KEYS.rooms);
    if(!subs.length || !rooms.length){ toast('Add subjects & rooms first','error'); return; }
    const tt = {};
    const alerts = [];
    for(const sub of subs){
      let assigned = 0;
      outer:
      for(const day of DAYS){
        for(const slot of SLOTS){
          if(assigned>=sub.hours) break outer;
          const key = `${day}|${slot}`;
          if(tt[key]) continue;
          // find free room
          const usedRooms = Object.entries(tt).filter(([k])=>k.startsWith(day+'|')&&k.endsWith(slot)).map(([,v])=>v.room);
          const room = rooms.find(r=>!Object.values(tt).some(v=>v.room===r.id && Object.keys(tt).find(k=>tt[k]===v)===key));
          // simpler: pick first room not conflicting in that slot
          const slotEntries = Object.entries(tt).filter(([k])=>k===key);
          const facultyBusy = Object.entries(tt).some(([k,v])=>k===key && v.faculty===sub.faculty);
          if(facultyBusy) continue;
          const freeRoom = rooms.find(r=>!Object.entries(tt).some(([k,v])=>k===key && v.room===r.id));
          if(!freeRoom) continue;
          tt[key] = {code:sub.code, name:sub.name, faculty:sub.faculty, room:freeRoom.id};
          assigned++;
        }
      }
      if(assigned<sub.hours) alerts.push(`Could only schedule ${assigned}/${sub.hours} hrs for ${sub.name}`);
    }
    Storage.set(KEYS.tt, tt);
    const box = document.getElementById('alerts');
    box.innerHTML = alerts.length
      ? alerts.map(a=>`<div class="alert error">⚠ ${a}</div>`).join('')
      : `<div class="alert success">✔ Timetable generated with no conflicts</div>`;
    Viewer.render(); App.refresh();
    toast('Timetable generated');
  },
  init(){
    const fillDropdowns = ()=>{
      mDay.innerHTML = DAYS.map(d=>`<option>${d}</option>`).join('');
      mSlot.innerHTML = SLOTS.map(s=>`<option>${s}</option>`).join('');
      mSubject.innerHTML = Storage.get(KEYS.subjects).map(s=>`<option value="${s.code}">${s.code} - ${s.name}</option>`).join('');
      mRoom.innerHTML = Storage.get(KEYS.rooms).map(r=>`<option value="${r.id}">${r.id} - ${r.name}</option>`).join('');
    };
    fillDropdowns();
    Scheduler._fill = fillDropdowns;

    document.getElementById('manualForm').onsubmit = e=>{
      e.preventDefault();
      const err = Scheduler.assign(mDay.value, mSlot.value, mSubject.value, mRoom.value);
      const box = document.getElementById('alerts');
      if(err){ box.innerHTML = `<div class="alert error">⚠ ${err}</div>`; toast(err,'error'); }
      else { box.innerHTML = `<div class="alert success">✔ Assigned successfully</div>`; toast('Assigned'); Viewer.render(); App.refresh(); }
    };
    document.getElementById('autoGenBtn').onclick = ()=>Scheduler.autoGenerate();
    document.getElementById('clearTTBtn').onclick = ()=>{
      if(confirm('Clear entire timetable?')){ Storage.set(KEYS.tt,{}); Viewer.render(); App.refresh(); toast('Cleared'); }
    };
  }
};
