const Storage = {
  get(key, def=[]){ try{ return JSON.parse(localStorage.getItem(key)) ?? def }catch{ return def } },
  set(key, val){ localStorage.setItem(key, JSON.stringify(val)) }
};
const KEYS = { rooms:'scs_rooms', faculty:'scs_faculty', subjects:'scs_subjects', tt:'scs_tt' };
const DAYS = ['Monday','Tuesday','Wednesday','Thursday','Friday'];
const SLOTS = ['09:00-10:00','10:00-11:00','11:00-12:00','12:00-13:00','14:00-15:00','15:00-16:00'];

function toast(msg, type='success'){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = type==='error' ? 'var(--danger)' : type==='success' ? 'var(--success)' : 'var(--text)';
  t.style.color = '#fff';
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2500);
}

