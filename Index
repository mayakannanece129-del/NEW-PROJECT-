<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Smart Classroom & Timetable Scheduler</title>
<link rel="stylesheet" href="css/style.css"/>
<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.31/jspdf.plugin.autotable.min.js"></script>
</head>
<body>
<div id="loader" class="loader"><div class="spinner"></div></div>

<div class="app">
  <aside class="sidebar" id="sidebar">
    <div class="brand">
      <i class="fa-solid fa-graduation-cap"></i>
      <h2>SmartSched</h2>
    </div>
    <nav>
      <a href="#" class="nav-link active" data-page="dashboard"><i class="fa-solid fa-gauge-high"></i> Dashboard</a>
      <a href="#" class="nav-link" data-page="classrooms"><i class="fa-solid fa-door-open"></i> Classrooms</a>
      <a href="#" class="nav-link" data-page="faculty"><i class="fa-solid fa-user-tie"></i> Faculty</a>
      <a href="#" class="nav-link" data-page="subjects"><i class="fa-solid fa-book"></i> Subjects</a>
      <a href="#" class="nav-link" data-page="scheduler"><i class="fa-solid fa-calendar-plus"></i> Scheduler</a>
      <a href="#" class="nav-link" data-page="viewer"><i class="fa-solid fa-table"></i> Timetable</a>
    </nav>
    <div class="sidebar-footer">
      <button id="themeToggle" class="theme-btn"><i class="fa-solid fa-moon"></i> Dark Mode</button>
    </div>
  </aside>

  <main class="main">
    <header class="topbar">
      <button class="menu-btn" id="menuBtn"><i class="fa-solid fa-bars"></i></button>
      <h1 id="pageTitle">Dashboard</h1>
      <div class="user"><i class="fa-solid fa-user-circle"></i> Admin</div>
    </header>

    <section id="dashboard" class="page active">
      <div class="stats">
        <div class="stat-card grad1"><i class="fa-solid fa-door-open"></i><div><h3 id="statRooms">0</h3><p>Classrooms</p></div></div>
        <div class="stat-card grad2"><i class="fa-solid fa-user-tie"></i><div><h3 id="statFaculty">0</h3><p>Faculty</p></div></div>
        <div class="stat-card grad3"><i class="fa-solid fa-book"></i><div><h3 id="statSubjects">0</h3><p>Subjects</p></div></div>
        <div class="stat-card grad4"><i class="fa-solid fa-calendar-check"></i><div><h3 id="statClasses">0</h3><p>Scheduled Classes</p></div></div>
      </div>
      <div class="welcome card">
        <h2>Welcome to Smart Classroom & Timetable Scheduler</h2>
        <p>Manage classrooms, faculty and subjects. Build conflict-free timetables with one click.</p>
        <ul>
          <li>✔ Add classrooms, faculty, subjects</li>
          <li>✔ Auto-generate weekly timetable</li>
          <li>✔ Conflict detection for faculty & rooms</li>
          <li>✔ Export to PDF / CSV</li>
        </ul>
      </div>
    </section>

    <section id="classrooms" class="page">
      <div class="card">
        <h2>Classrooms</h2>
        <form id="classroomForm" class="row-form">
          <input type="text" id="croomId" placeholder="Room ID (e.g. R101)" required/>
          <input type="text" id="croomName" placeholder="Room Name" required/>
          <input type="number" id="croomCap" placeholder="Capacity" required/>
          <select id="croomType"><option>Lecture</option><option>Lab</option><option>Seminar</option></select>
          <button type="submit"><i class="fa-solid fa-plus"></i> Add</button>
        </form>
        <table id="classroomTable" class="data-table"><thead><tr><th>ID</th><th>Name</th><th>Capacity</th><th>Type</th><th>Action</th></tr></thead><tbody></tbody></table>
      </div>
    </section>

    <section id="faculty" class="page">
      <div class="card">
        <h2>Faculty</h2>
        <form id="facultyForm" class="row-form">
          <input type="text" id="facId" placeholder="Faculty ID" required/>
          <input type="text" id="facName" placeholder="Name" required/>
          <input type="text" id="facDept" placeholder="Department" required/>
          <input type="email" id="facEmail" placeholder="Email"/>
          <button type="submit"><i class="fa-solid fa-plus"></i> Add</button>
        </form>
        <table id="facultyTable" class="data-table"><thead><tr><th>ID</th><th>Name</th><th>Dept</th><th>Email</th><th>Action</th></tr></thead><tbody></tbody></table>
      </div>
    </section>

    <section id="subjects" class="page">
      <div class="card">
        <h2>Subjects</h2>
        <form id="subjectForm" class="row-form">
          <input type="text" id="subCode" placeholder="Code (e.g. CS101)" required/>
          <input type="text" id="subName" placeholder="Subject Name" required/>
          <select id="subFaculty"></select>
          <input type="number" id="subHours" placeholder="Weekly Hours" min="1" max="10" required/>
          <button type="submit"><i class="fa-solid fa-plus"></i> Add</button>
        </form>
        <table id="subjectTable" class="data-table"><thead><tr><th>Code</th><th>Name</th><th>Faculty</th><th>Hrs/Week</th><th>Action</th></tr></thead><tbody></tbody></table>
      </div>
    </section>

    <section id="scheduler" class="page">
      <div class="card">
        <h2>Timetable Scheduler</h2>
        <div class="scheduler-actions">
          <button id="autoGenBtn" class="primary"><i class="fa-solid fa-wand-magic-sparkles"></i> Auto-Generate Timetable</button>
          <button id="clearTTBtn" class="danger"><i class="fa-solid fa-trash"></i> Clear Timetable</button>
        </div>
        <h3>Manual Assignment</h3>
        <form id="manualForm" class="row-form">
          <select id="mDay"></select>
          <select id="mSlot"></select>
          <select id="mSubject"></select>
          <select id="mRoom"></select>
          <button type="submit"><i class="fa-solid fa-plus"></i> Assign</button>
        </form>
        <div id="alerts"></div>
      </div>
    </section>

    <section id="viewer" class="page">
      <div class="card">
        <h2>Weekly Timetable</h2>
        <div class="scheduler-actions">
          <button id="exportPDF" class="primary"><i class="fa-solid fa-file-pdf"></i> Export PDF</button>
          <button id="exportCSV" class="primary"><i class="fa-solid fa-file-csv"></i> Export CSV</button>
        </div>
        <div class="tt-wrap">
          <table id="timetable" class="timetable"></table>
        </div>
      </div>
    </section>
  </main>
</div>

<div id="toast" class="toast"></div>

<script src="js/storage.js"></script>
<script src="js/sampleData.js"></script>
<script src="js/classrooms.js"></script>
<script src="js/faculty.js"></script>
<script src="js/subjects.js"></script>
<script src="js/scheduler.js"></script>
<script src="js/viewer.js"></script>
<script src="js/app.js"></script>
</body>
</html>
